# Copy this file to .env and adjust as needed:  cp .env.example .env
# Loaded automatically by `npm start` (node --env-file-if-exists=.env).

# HTTP server port
PORT=3066

# Working directory of the interactive `claude` session (default: current dir)
# CLAUDE_CWD=/path/to/project

# Model alias for the session (default: claude's default). Ex: opus, sonnet
# CLAUDE_MODEL=opus

# If set, /v1/messages requires this value in the `x-api-key` header
# API_KEY=change-me
